# 文本模型配置（规则解析）
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=deepseek-v3-2-251201

# 多模态模型配置（海报审核）
MLLM_API_KEY_0=your_mllm_api_key_here
MLLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
MLLM_MODEL=doubao-seed-2-0-pro-260215

# 应用配置
LOG_LEVEL=INFO


# Java 用户信息回源鉴权（可选）
ENABLE_JAVA_AUTH=false
JAVA_USERINFO_URL=
JAVA_TOKEN_HEADER=Token
JAVA_AUTH_TIMEOUT_SECONDS=5

# 用户隔离开关（非管理员仅可查看自己任务）
ENABLE_USER_ISOLATION=true

# Celery + Redis（异步任务）
USE_CELERY=false
REDIS_URL=redis://:redis123456@localhost:6379/0
REDIS_RESULT_URL=redis://:redis123456@localhost:6379/1
REDIS_CACHE_URL=redis://:redis123456@localhost:6379/2
CELERY_WORKER_CONCURRENCY=70
TASK_STATUS_TTL_SECONDS=3600
