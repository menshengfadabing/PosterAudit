# ===== 基础 =====
TZ=Asia/Shanghai

# ===== 模型配置（文本） =====
LLM_API_KEY=replace_me
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=deepseek-v3-2-251201

# ===== 模型配置（多模态） =====
MLLM_API_KEY_0=replace_me
# MLLM_API_KEY_1=replace_me
# MLLM_API_KEY_2=replace_me
MLLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
MLLM_MODEL=doubao-seed-2-0-pro-260215

# ===== 鉴权与隔离 =====
ENABLE_JAVA_AUTH=false
JAVA_USERINFO_URL=
JAVA_TOKEN_HEADER=Token
JAVA_AUTH_TIMEOUT_SECONDS=5
ALLOW_HEADER_AUTH_FALLBACK=true
ENABLE_USER_ISOLATION=true
ALLOWED_API_KEYS=
REQUIRE_API_KEY=false
CORS_ALLOW_ORIGINS=*

# ===== 服务配置 =====
USE_CELERY=true
CELERY_WORKER_CONCURRENCY=8
LOG_LEVEL=INFO
API_BIND_PORT=18080
CELERY_CONCURRENCY=2

# ===== 数据库与缓存（compose 内部服务名） =====
DATABASE_URL=postgresql+psycopg2://postgres:postgres123456@postgres:5432/app
REDIS_URL=redis://:redis123456@redis:6379/0
REDIS_RESULT_URL=redis://:redis123456@redis:6379/1
REDIS_CACHE_URL=redis://:redis123456@redis:6379/2

# ===== PostgreSQL/Redis 初始密码 =====
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123456
REDIS_PASSWORD=redis123456
